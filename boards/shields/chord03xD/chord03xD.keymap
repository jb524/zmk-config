#include <behaviors.dtsi>
#include <dt-bindings/zmk/keys.h>
#include <dt-bindings/zmk/bt.h>

#define SWITCH 1
#define SYS 2

/ {
    behaviors {
        ts: tog_sl {
            compatible = "zmk,behavior-hold-tap";
            #binding-cells = <2>;
            flavor = "hold-preferred";
            tapping-term-ms = <200>;
            quick-tap-ms = <200>;
            require-prior-idle-ms = <100>;
            bindings = <&tog>, <&sl>;
            display-name = "tog-sl";
        };
        
        skkp: sk_kp {
            compatible = "zmk,behavior-hold-tap";
            #binding-cells = <2>;
            flavor = "hold-preferred";
            tapping-term-ms = <200>;
            quick-tap-ms = <200>;
            require-prior-idle-ms = <100>;
            bindings = <&sk>, <&kp>;
            display-name = "sk-kp";
        };
        
        kpsk: kp_sk {
            compatible = "zmk,behavior-hold-tap";
            #binding-cells = <2>;
            flavor = "hold-preferred";
            tapping-term-ms = <200>;
            quick-tap-ms = <200>;
            require-prior-idle-ms = <100>;
            bindings = <&kp>, <&sk>;
            display-name = "kp-sk";
        };
        
        zmksk: zmk_sk {
            compatible = "zmk,behavior-hold-tap";
            #binding-cells = <2>;
            flavor = "tap-preferred";
            tapping-term-ms = <200>;
            quick-tap-ms = <200>;
            require-prior-idle-ms = <100>;
            bindings = <&studio_unlock>, <&sk>;
            display-name = "zmk-kp";
        };
        
        btkp: bt_kp {
            compatible = "zmk,behavior-hold-tap";
            #binding-cells = <2>;
            flavor = "tap-preferred";
            tapping-term-ms = <200>;
            quick-tap-ms = <200>;
            require-prior-idle-ms = <100>;
            bindings = <&bt>, <&kp>;
            display-name = "btc-sk";
        };

        // Tuned key-key hold-tap. Drop-in replacement for built-in &mt.
        // Why custom: the built-in &mt's timing knobs aren't tunable in-place,
        // and its default flavor is hold-preferred which is too aggressive for
        // our case (holds here are non-mod things: HOME, F-keys, modded symbols
        // like LS(N5)='%'). Tap-preferred biases toward the letter/tap unless
        // the keys are clearly held past tapping-term with nothing else happening.
        // Use: &htk HOLD_KEY TAP_KEY  (everywhere &htk was used)
        htk: htk {
            compatible = "zmk,behavior-hold-tap";
            #binding-cells = <2>;
            flavor = "tap-preferred";
            tapping-term-ms = <200>;
            quick-tap-ms = <200>;
            require-prior-idle-ms = <100>;
            bindings = <&kp>, <&kp>;
            display-name = "htk";
        };

        // --- Behaviors for combo_012 / combo_1_012 / combo_234 ---
        // ZMK constraint: tap-dance requires #binding-cells=<0> and all
        // sub-bindings fully pre-parameterized. Hold-tap forwards params,
        // but here we keep everything 0-cell for symmetry and simplicity.
        // To change a modifier/layer: edit the marked "<== EDIT" line in
        // the behavior body. The combo invocation line stays untouched.

        // Tap-dance for combo_012 tap side:
        //   1 tap  = sticky SWITCH layer
        //   2 taps = toggle SWITCH layer
        //   3 taps = toggle SYS layer (drill to system layer)
        td_layer: td_layer {
            compatible = "zmk,behavior-tap-dance";
            #binding-cells = <0>;
            tapping-term-ms = <200>;
            bindings = <&sl SWITCH>, <&tog SWITCH>, <&tog SYS>;
        };

        // Hold-tap for combo_012:
        //   hold = sticky modifier (caller-provided; see combo_012 line)
        //   tap  = td_layer (above, all baked)
        // ZMK constraint: hold-tap bindings are bare phandles (no baked params),
        // so the modifier MUST be passed at the combo invocation.
        // Asymmetric cells: &sk=1, &td_layer=0, sum=1 => #binding-cells=<1>.
        ht_mod_tdlayer: ht_mod_tdlayer {
            compatible = "zmk,behavior-hold-tap";
            #binding-cells = <1>;
            flavor = "hold-preferred";
            tapping-term-ms = <200>;
            quick-tap-ms = <200>;
            require-prior-idle-ms = <100>;
            bindings = <&sk &td_layer>;
        };

        // Tap-dance for combo_1_012:
        //   1 tap  = sticky LCTRL          <== EDIT modifier here
        //   2 taps = toggle SWITCH off (structural; leave as-is)
        td_mod_togSW: td_mod_togSW {
            compatible = "zmk,behavior-tap-dance";
            #binding-cells = <0>;
            tapping-term-ms = <200>;
            bindings = <&sk LCTRL>, <&tog SWITCH>;
        };

        // Tap-dance for combo_234 tap side:
        //   1 tap  = sticky LSHIFT         <== EDIT mod here (must match 2-tap)
        //   2 taps = locked LSHIFT (kt)    <== EDIT mod here (must match 1-tap)
        // &kt = key-toggle: first invocation latches the mod, second releases it.
        td_mod: td_mod {
            compatible = "zmk,behavior-tap-dance";
            #binding-cells = <0>;
            tapping-term-ms = <200>;
            bindings = <&sk LSHIFT>, <&kt LSHIFT>;
        };

        // Hold-tap for combo_234:
        //   hold = sticky modifier (caller-provided; see combo_234 line)
        //   tap  = td_mod (above, all baked)
        // Same constraint as ht_mod_tdlayer above: bare phandles only.
        ht_mod_tdmod: ht_mod_tdmod {
            compatible = "zmk,behavior-hold-tap";
            #binding-cells = <1>;
            flavor = "hold-preferred";
            tapping-term-ms = <200>;
            quick-tap-ms = <200>;
            require-prior-idle-ms = <100>;
            bindings = <&sk &td_mod>;
        };
    };
    
    combos {
        compatible = "zmk,combos";
        
        combo_34 {
            timeout-ms = <50>; // 50 ms to press all keys
            bindings = <&htk HOME N>; // output of the combo
            layers = <0>; //layers where the combo can be activated
            key-positions = <3 4>; // keys used in combo trigger
        };
        
        combo_23 {
            timeout-ms = <50>;
            key-positions = <2 3>;
            layers = <0>;
            bindings = <&htk PG_UP T>;
        };
        
        combo_12 {
            timeout-ms = <50>;
            key-positions = <1 2>;
            layers = <0>;
            bindings = <&htk END L>;
        };
        
        combo_01 {
            timeout-ms = <50>;
            key-positions = <0 1>;
            layers = <0>;
            bindings = <&htk LS(N9) S>;
        };
        
        combo_24 {
            timeout-ms = <50>;
            key-positions = <2 4>;
            layers = <0>;
            bindings = <&htk LS(DOT) D>;
        };
        
        combo_13 {
            timeout-ms = <50>;
            key-positions = <1 3>;
            layers = <0>;
            bindings = <&htk LS(COMMA) M>;
        };
        
        combo_02 {
            timeout-ms = <50>;
            key-positions = <0 2>;
            layers = <0>;
            bindings = <&htk LS(N8) Z>;
        };
        
        combo_14 {
            timeout-ms = <50>;
            key-positions = <1 4>;
            layers = <0>;
            bindings = <&htk PG_DN K>;
        };
        
        combo_03 {
            timeout-ms = <50>;
            key-positions = <0 3>;
            layers = <0>;
            bindings = <&htk LS(N7) B>;
        };
        
        combo_04 {
            timeout-ms = <50>;
            key-positions = <0 4>;
            layers = <0>;
            bindings = <&htk LS(N6) Y>;
        };
        
        combo_024 {
            timeout-ms = <50>;
            key-positions = <0 2 4>;
            layers = <0>;
            bindings = <&htk LS(GRAVE) W>;
        };
        
        combo_0123 {
            timeout-ms = <50>;
            key-positions = <0 1 2 3>;
            layers = <0>;
            bindings = <&htk LS(N0) H>;
        };
        
        combo_0124 {
            timeout-ms = <50>;
            key-positions = <0 1 2 4>;
            layers = <0>;
            bindings = <&htk LS(SEMI) C>;
        };
        
        combo_0134 {
            timeout-ms = <50>;
            key-positions = <0 1 3 4>;
            layers = <0>;
            bindings = <&htk LS(EQUAL) V>;
        };
        
        combo_0234 {
            timeout-ms = <50>;
            key-positions = <0 2 3 4>;
            layers = <0>;
            bindings = <&htk LS(RBKT) J>;
        };
        
        combo_1234 {
            timeout-ms = <50>;
            key-positions = <1 2 3 4>;
            layers = <0>;
            bindings = <&htk LS(LBKT) R>;
        };
        
        combo_124 {
            timeout-ms = <50>;
            key-positions = <1 2 4>;
            layers = <0>;
            bindings = <&htk LS(BSLH) G>;
        };
        
        combo_013 {
            timeout-ms = <50>;
            key-positions = <0 1 3>;
            layers = <0>;
            bindings = <&htk LS(MINUS) X>;
        };
        
        combo_134 {
            timeout-ms = <50>;
            key-positions = <1 3 4>;
            layers = <0>;
            bindings = <&htk LS(SLASH) F>;
        };
        
        combo_023 {
            timeout-ms = <50>;
            key-positions = <0 2 3>;
            layers = <0>;
            bindings = <&htk LS(SQT) Q>;
        };
        
        combo_014 {
            timeout-ms = <50>;
            key-positions = <0 1 4>;
            layers = <0>;
            bindings = <&htk F4 ENTER>; //kp kp 
        };
        
        combo_034 {
            timeout-ms = <50>;
            key-positions = <0 3 4>;
            layers = <0>;
            bindings = <&skkp LGUI P>;
        };
        
        combo_234 {
            timeout-ms = <50>;
            key-positions = <2 3 4>;
            layers = <0>;
            bindings = <&ht_mod_tdmod LALT>; // hold-mod (only)
        };
        
        combo_123 {
            timeout-ms = <50>;
            key-positions = <1 2 3>;
            layers = <0>;
            bindings = <&htk F11 BACKSPACE>;
        };
        
        combo_012 {
            timeout-ms = <50>;
            key-positions = <0 1 2>;
            layers = <0>;
            bindings = <&ht_mod_tdlayer LCTRL>; // hold-mod (only)
        };
        
        combo_01234 {
            timeout-ms = <50>;
            key-positions = <0 1 2 3 4>;
            layers = <0>;
            bindings = <&htk LS(TAB) SPACE>;
        };
        
        combo_1_34 {
            timeout-ms = <50>; 
            bindings = <&kp LEFT>; 
            layers = <1>;
            key-positions = <3 4>; 
        };
        
        combo_1_23 {
            timeout-ms = <50>;
            key-positions = <2 3>;
            layers = <1>;
            bindings = <&kp UP>;
        };
        
        combo_1_12 {
            timeout-ms = <50>;
            key-positions = <1 2>;
            layers = <1>;
            bindings = <&kp RIGHT>;
        };
        
        combo_1_01 {
            timeout-ms = <50>;
            key-positions = <0 1>;
            layers = <1>;
            bindings = <&kp N9>;
        };
        
        combo_1_24 {
            timeout-ms = <50>;
            key-positions = <2 4>;
            layers = <1>;
            bindings = <&kp DOT>;
        };
        
        combo_1_13 {
            timeout-ms = <50>;
            key-positions = <1 3>;
            layers = <1>;
            bindings = <&kp COMMA>;
        };
        
        combo_1_02 {
            timeout-ms = <50>;
            key-positions = <0 2>;
            layers = <1>;
            bindings = <&kp N8>;
        };
        
        combo_1_14 {
            timeout-ms = <50>;
            key-positions = <1 4>;
            layers = <1>;
            bindings = <&kp DOWN>;
        };
        
        combo_1_03 {
            timeout-ms = <50>;
            key-positions = <0 3>;
            layers = <1>;
            bindings = <&kp N7>;
        };
        
        combo_1_04 {
            timeout-ms = <50>;
            key-positions = <0 4>;
            layers = <1>;
            bindings = <&kp N6>;
        };
        
        combo_1_024 {
            timeout-ms = <50>;
            key-positions = <0 2 4>;
            layers = <1>;
            bindings = <&kp GRAVE>;
        };
        
        combo_1_0123 {
            timeout-ms = <50>;
            key-positions = <0 1 2 3>;
            layers = <1>;
            bindings = <&kp N0>;
        };
        
        combo_1_0124 {
            timeout-ms = <50>;
            key-positions = <0 1 2 4>;
            layers = <1>;
            bindings = <&kp SEMI>;
        };
        
        combo_1_0134 {
            timeout-ms = <50>;
            key-positions = <0 1 3 4>;
            layers = <1>;
            bindings = <&kp EQUAL>;
        };
        
        combo_1_0234 {
            timeout-ms = <50>;
            key-positions = <0 2 3 4>;
            layers = <1>;
            bindings = <&kp RBKT>;
        };
        
        combo_1_1234 {
            timeout-ms = <50>;
            key-positions = <1 2 3 4>;
            layers = <1>;
            bindings = <&kp LBKT>;
        };
        
        combo_1_124 {
            timeout-ms = <50>;
            key-positions = <1 2 4>;
            layers = <1>;
            bindings = <&kp BSLH>;
        };
        
        combo_1_013 {
            timeout-ms = <50>;
            key-positions = <0 1 3>;
            layers = <1>;
            bindings = <&kp MINUS>;
        };
        
        combo_1_134 {
            timeout-ms = <50>;
            key-positions = <1 3 4>;
            layers = <1>;
            bindings = <&kp SLASH>;
        };
        
        combo_1_023 {
            timeout-ms = <50>;
            key-positions = <0 2 3>;
            layers = <1>;
            bindings = <&kp SQT>;
        };
        
        combo_1_014 {
            timeout-ms = <50>;
            key-positions = <0 1 4>;
            layers = <1>;
            bindings = <&kp ESC>;
        };
        
        combo_1_034 {
            timeout-ms = <50>;
            key-positions = <0 3 4>;
            layers = <1>;
            bindings = <&sk LGUI>;
        };
        
        combo_1_234 {
            timeout-ms = <50>;
            key-positions = <2 3 4>;
            layers = <1>;
            bindings = <&sk LALT>; 
        };
        
        combo_1_123 {
            timeout-ms = <50>;
            key-positions = <1 2 3>;
            layers = <1>;
            bindings = <&kp DEL>;
        };
        
        combo_1_012 {
            timeout-ms = <50>;
            key-positions = <0 1 2>;
            layers = <1>;
            bindings = <&td_mod_togSW>;
        };
        
        combo_1_01234 {
            timeout-ms = <50>;
            key-positions = <0 1 2 3 4>;
            layers = <1>;
            bindings = <&kp TAB>;
        };

        // --- Layer 2 (SYS) combos: F-keys, page nav, BT, Studio, exit ---

        // F-keys F6..F12 (F1..F5 are on sys_layer single keys)
        combo_2_04 {
            timeout-ms = <50>;
            key-positions = <0 4>;
            layers = <SYS>;
            bindings = <&kp F6>;
        };

        combo_2_03 {
            timeout-ms = <50>;
            key-positions = <0 3>;
            layers = <SYS>;
            bindings = <&kp F7>;
        };

        combo_2_02 {
            timeout-ms = <50>;
            key-positions = <0 2>;
            layers = <SYS>;
            bindings = <&kp F8>;
        };

        combo_2_01 {
            timeout-ms = <50>;
            key-positions = <0 1>;
            layers = <SYS>;
            bindings = <&kp F9>;
        };

        combo_2_0123 {
            timeout-ms = <50>;
            key-positions = <0 1 2 3>;
            layers = <SYS>;
            bindings = <&kp F10>;
        };

        combo_2_013 {
            timeout-ms = <50>;
            key-positions = <0 1 3>;
            layers = <SYS>;
            bindings = <&kp F11>;
        };

        combo_2_0134 {
            timeout-ms = <50>;
            key-positions = <0 1 3 4>;
            layers = <SYS>;
            bindings = <&kp F12>;
        };

        // Page navigation (mirrors arrow-key positions on Layer 1)
        combo_2_23 {
            timeout-ms = <50>;
            key-positions = <2 3>;
            layers = <SYS>;
            bindings = <&kp PG_UP>;
        };

        combo_2_14 {
            timeout-ms = <50>;
            key-positions = <1 4>;
            layers = <SYS>;
            bindings = <&kp PG_DN>;
        };

        combo_2_34 {
            timeout-ms = <50>;
            key-positions = <3 4>;
            layers = <SYS>;
            bindings = <&kp HOME>;
        };

        combo_2_12 {
            timeout-ms = <50>;
            key-positions = <1 2>;
            layers = <SYS>;
            bindings = <&kp END>;
        };

        // Bluetooth device selection (slots 0/1/2)
        combo_2_1234 {
            timeout-ms = <50>;
            key-positions = <1 2 3 4>;
            layers = <SYS>;
            bindings = <&bt BT_SEL 0>;
        };

        combo_2_0234 {
            timeout-ms = <50>;
            key-positions = <0 2 3 4>;
            layers = <SYS>;
            bindings = <&bt BT_SEL 1>;
        };

        combo_2_124 {
            timeout-ms = <50>;
            key-positions = <1 2 4>;
            layers = <SYS>;
            bindings = <&bt BT_SEL 2>;
        };

        // Bluetooth clear (current profile -> back into advertising for re-pair)
        combo_2_123 {
            timeout-ms = <50>;
            key-positions = <1 2 3>;
            layers = <SYS>;
            bindings = <&bt BT_CLR>;
        };

        // ZMK Studio unlock
        combo_2_014 {
            timeout-ms = <50>;
            key-positions = <0 1 4>;
            layers = <SYS>;
            bindings = <&studio_unlock>;
        };

        // Exit SYS layer (direct toggle, no modifier needed here)
        combo_2_012 {
            timeout-ms = <50>;
            key-positions = <0 1 2>;
            layers = <SYS>;
            bindings = <&tog SYS>;
        };

    };

    keymap {
        compatible = "zmk,keymap";

        base_layer {
            display-name = "Base";
            bindings = < &htk LS(N5) U    &htk LS(N4) O    &htk LS(N3) I    &htk LS(N2) E   &htk LS(N1) A >;
        };
        
        switch_layer {
            display-name = "Switch";
            bindings = < &kp N5    &kp N4    &kp N3    &kp N2    &kp N1 >;
        };

        sys_layer {
            display-name = "Sys";
            bindings = < &kp F5    &kp F4    &kp F3    &kp F2    &kp F1 >;
        };
    };
 };
